  "description": "A Lovelace card for Home Assistant that tracks visited National Park Service sites on an interactive map.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FCjosh/lovelace-nps-parks-card.git"
  },
